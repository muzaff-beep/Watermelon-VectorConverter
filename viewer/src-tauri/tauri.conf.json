{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Watermelon Vector Viewer",
  "version": "0.1.0",
  "identifier": "com.watermelon.viewer",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5174",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Watermelon Vector Viewer",
        "width": 900,
        "height": 700,
        "minWidth": 400,
        "minHeight": 300,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "capabilities": [
        {
          "identifier": "viewer-capability",
          "description": "Viewer window permissions",
          "windows": ["main"],
          "permissions": ["core:default", "dialog:allow-open"]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["svg"],
        "name": "SVG Image",
        "description": "Scalable Vector Graphics",
        "role": "Viewer",
        "mimeType": "image/svg+xml"
      },
      {
        "ext": ["xml"],
        "name": "VectorDrawable XML",
        "description": "Android VectorDrawable",
        "role": "Viewer",
        "mimeType": "text/xml"
      }
    ]
  }
}
