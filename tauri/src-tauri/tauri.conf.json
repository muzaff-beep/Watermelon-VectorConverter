{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Watermelon Vector Converter",
  "version": "0.1.0",
  "identifier": "com.watermelon.converter",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Watermelon Vector Converter",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "capabilities": [
        {
          "identifier": "main-capability",
          "description": "Main window permissions",
          "windows": [
            "main"
          ],
          "permissions": [
            "core:default",
            "dialog:allow-open",
            "dialog:allow-save",
            "fs:read-all",
            "fs:write-all"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "installer/hooks.nsi"
      }
    },
    "externalBin": [
      "binaries/wvgc-viewer"
    ]
  }
}