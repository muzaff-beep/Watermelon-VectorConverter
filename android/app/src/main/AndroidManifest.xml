<!-- No INTERNET permission by design (offline-first, zero network). -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- Full filesystem access for the file manager tab. This is a sensitive
         permission: the user must grant it via a system Settings screen (no
         normal runtime dialog exists for it), and Play Store distribution
         requires the app's core purpose to be file management to qualify.
         Used here for personal/sideload builds per project decision. -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />

    <application
        android:name=".WvgcApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Watermelon">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
            android:theme="@style/Theme.Watermelon">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    
        <!-- SVG/VectorDrawable viewer -->
        <activity
            android:name=".ui.viewer.SvgViewerActivity"
            android:exported="true"
            android:theme="@style/Theme.Watermelon">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="image/svg+xml" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/xml" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/xml" />
            </intent-filter>
        </activity>
    </application>
</manifest>
